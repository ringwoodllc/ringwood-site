{
  "name": "ringwood-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Native iOS + Android shell that wraps the Ringwood field-ops web app.",
  "scripts": {
    "assets": "capacitor-assets generate --assetPath assets --iconBackgroundColor '#1f3d2b' --splashBackgroundColor '#1f3d2b'",
    "sync": "cap sync",
    "ios": "cap open ios",
    "android": "cap open android",
    "add:ios": "cap add ios",
    "add:android": "cap add android"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/android": "^6.1.2",
    "@capacitor/camera": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@capacitor/assets": "^3.0.5"
  }
}
