{
  "appId": "ai.ringwood.app",
  "appName": "Ringwood",
  "webDir": "www",
  "server": {
    "url": "https://app.ringwood.ai",
    "cleartext": false
  },
  "ios": {
    "contentInset": "always"
  },
  "android": {
    "allowMixedContent": false
  },
  "backgroundColor": "#1f3d2b",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#1f3d2b",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
